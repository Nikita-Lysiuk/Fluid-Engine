@article{brackbill1986flip,
  title    = {FLIP: A method for adaptively zoned, particle-in-cell calculations of fluid flows in two dimensions},
  journal  = {Journal of Computational Physics},
  volume   = {65},
  number   = {2},
  pages    = {314-343},
  year     = {1986},
  issn     = {0021-9991},
