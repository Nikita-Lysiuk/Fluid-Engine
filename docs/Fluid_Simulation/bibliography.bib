  url      = {https://www.sciencedirect.com/science/article/pii/0021999186902111},
  author   = {J.U. Brackbill and H.M. Ruppel},
  abstract = {A method is presented for calculating fluid flow in two dimensions using a full particle-in-cell representation on an adaptively zoned grid. The method has many interesting properties, among them an almost total absence of numerical dissipation and the ability to represent large variations in the data. The method is described using a standard formalism and its properties are illustrated by supersonic flow over a step and the interaction of a shock with a thin foil.}
}

